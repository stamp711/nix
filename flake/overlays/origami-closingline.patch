diff --git a/lua/origami/features/foldtext.lua b/lua/origami/features/foldtext.lua
index 04c87cd..43b44f0 100644
--- a/lua/origami/features/foldtext.lua
+++ b/lua/origami/features/foldtext.lua
@@ -110,6 +110,28 @@ end
 ---@param buf number
 ---@param foldstart number
 ---@return number foldend
+--- Whether the fold's last line leads with a closer rather than a body statement.
+---@param buf number
+---@param foldstart number
+---@param foldend number
+---@return boolean
+local function isClosingLine(buf, foldstart, foldend)
+	local last = vim.api.nvim_buf_get_lines(buf, foldend - 1, foldend, false)[1] or ""
+	local col = last:find("%S")
+	if not col then return false end
+	local ok, node = pcall(vim.treesitter.get_node, { bufnr = buf, pos = { foldend - 1, col - 1 } })
+	if ok and node then
+		while node and not node:named() do
+			node = node:parent()
+		end
+		-- leading node starts earlier = closes an outer block (closer); starts here = a body statement
+		if node then return (node:range()) < (foldend - 1) end
+	end
+	-- no parser: fall back to indentation, a closer aligns with the header
+	local first = vim.api.nvim_buf_get_lines(buf, foldstart - 1, foldstart, false)[1] or ""
+	return #(last:match("^%s*")) <= #(first:match("^%s*"))
+end
