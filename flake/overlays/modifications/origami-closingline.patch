--- a/lua/origami/features/foldtext.lua
+++ b/lua/origami/features/foldtext.lua
@@ -106,6 +106,58 @@ end
 
 --------------------------------------------------------------------------------
 
+--- Whether the fold's last line leads with a closer rather than a body statement.
+---@param buf number
+---@param foldstart number
+---@param foldend number
+---@return boolean
+local function isClosingLine(buf, foldstart, foldend)
+	local last = vim.api.nvim_buf_get_lines(buf, foldend - 1, foldend, false)[1] or ""
+	local col = last:find("%S")
+	if not col then return false end
+	local ok, node = pcall(vim.treesitter.get_node, { bufnr = buf, pos = { foldend - 1, col - 1 } })
+	if ok and node then
+		while node and not node:named() do
+			node = node:parent()
+		end
+		-- leading node starts earlier = closes an outer block (closer); starts here = a body statement
+		if node then return (node:range()) < (foldend - 1) end
+	end
+	-- no parser: fall back to indentation, a closer aligns with the header
+	local first = vim.api.nvim_buf_get_lines(buf, foldstart - 1, foldstart, false)[1] or ""
+	return #(last:match("^%s*")) <= #(first:match("^%s*"))
+end
+
+--- Syntax-highlight the closing line via treesitter, so it matches the first
+--- folded line instead of a single flat hlgroup.
+---@param buf number
+---@param row number 0-indexed line of the closing line
+---@param startCol number byte column of its first non-blank char
+---@param text string closing text, leading whitespace already removed
+---@param fallbackHl string used when there is no treesitter parser
+---@return Origami.VirtTextChunk[]
+local function highlightClosingLine(buf, row, startCol, text, fallbackHl)
+	local hasParser, parser = pcall(vim.treesitter.get_parser, buf)
+	if not hasParser or not parser then return { { text, { fallbackHl } } } end
+	parser:parse { row, row } -- the closing line is folded away, so not parsed yet
+
+	local chunks = {} ---@type Origami.VirtTextChunk[]
+	local segment, segmentHl
+	for i = 1, #text do
+		local captures = vim.treesitter.get_captures_at_pos(buf, row, startCol + i - 1)
+		local last = captures[#captures]
+		local hl = last and ("@" .. last.capture) or fallbackHl
+		if hl == segmentHl then
+			segment = segment .. text:sub(i, i)
+		else
+			if segment then table.insert(chunks, { segment, { segmentHl } }) end
+			segment, segmentHl = text:sub(i, i), hl
+		end
+	end
+	if segment then table.insert(chunks, { segment, { segmentHl } }) end
+	return chunks
+end
+
 ---@param win number
 ---@param buf number
 ---@param foldstart number
